    {
      "id": "2b21c61467c168d7702ca4aabe7578f63434380f",
      "source_id": "aihot",
      "source_name": "AI Hot",
      "source_type": "public_feed",
      "source_group": "aggregate",
      "source_weight": 2,
      "title": "在 Claude Code 中选择 Claude 模型与努力级别",
      "url": "https://aihot.virxact.com/items/cmraqmpst004cihogf6nqkgvh",
      "published_at": "2026-07-07T14:21:59Z",
      "summary": "Claude Code 提供模型（model）和努力级别（effort）两种设置。模型选择决定能力范围，更大模型（如 Claude Fable 5）在基准上优于 Claude Sonnet。努力级别不单是思考时间，还控制读取文件数、验证步骤及多步任务的推进深度。较高努力下 Claude 会自行读取文件、运行测试并复核；较低努力则更倾向请求用户提供上下文。若 Claude 已掌握上下文但仍出错，应换更强大模型；若因跳读文件或未运行测试而出错，则应提高努力级别。 🔗 阅读原文：https://claude.com/blog/claude-model-and-effort-level-in-claude-code via AI HOT · https://aihot.virxact.com/items/cmraqmp",
      "relevance_score": 3,
      "relevance_reasons": [
        "strong:claude",
        "strong:大模型",
        "source_penalty:aggregate_noise"
      ],
